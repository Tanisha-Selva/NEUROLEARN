# .env scaffold for NeuroLearnAI
# Uncomment and fill in the values to activate external integrations

# Gemini API Key (Replaces static response generation with dynamic LLM feedback)
# GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB URI (Replaces local JSON storage with a persistent database, e.g., MongoDB Atlas)
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
